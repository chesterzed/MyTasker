# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_MASTER_KEY=

# Telegram bot token from @BotFather
BOT_TOKEN=

# Прокси до api.telegram.org (если Telegram недоступен напрямую, например сервер в РФ).
# Укажи локальный порт своего прокси-клиента (throne/xray и т.п.):
#   socks5://127.0.0.1:2080   или   http://127.0.0.1:8080
# Пусто = прямое соединение.
TELEGRAM_PROXY=

# Ваш Telegram user id — /start сделает этот аккаунт админом, посмотреть здесь @userinfobot
ADMIN_TELEGRAM_ID=

# Optional, default http://localhost:11434
OLLAMA_HOST=

# Whisper (голосовые): модель tiny/base/small/medium, default small
WHISPER_MODEL=
# cpu или cuda, default cpu
WHISPER_DEVICE=

# Список моделей для /settings → Модель. Пары провайдер:модель через запятую,
# провайдер ∈ {claude, ollama}. Можно несколько моделей одного провайдера,
# напр. claude:claude-opus-4-8,claude:claude-opus-4-7. Модель ollama может
# содержать ':' (qwen2.5:14b) — это нормально. Пусто = дефолт ниже.
AI_MODELS=claude:claude-opus-4-8,ollama:qwen2.5:14b
