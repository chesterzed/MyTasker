# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_MASTER_KEY=

# Telegram bot token from @BotFather
BOT_TOKEN=

# Ваш Telegram user id — /start сделает этот аккаунт админом, посмотреть здесь @userinfobot
ADMIN_TELEGRAM_ID=

# Optional, default http://localhost:11434
OLLAMA_HOST=

# Whisper (голосовые): модель tiny/base/small/medium, default small
WHISPER_MODEL=
# cpu или cuda, default cpu
WHISPER_DEVICE=
